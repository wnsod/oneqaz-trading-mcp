{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.wnsod/oneqaz-trading-mcp",
  "title": "Trading Signal & Market Regime MCP Server",
  "description": "Trading signals, regime detection, Fear & Greed, positions for crypto, US and Korean stocks.",
  "version": "0.1.2",
  "repository": {
    "url": "https://github.com/oneqaz-trading/oneqaz-trading-mcp",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "oneqaz-trading-mcp",
      "version": "0.1.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DATA_ROOT",
          "description": "Root directory for market data files",
          "isRequired": false,
          "isSecret": false
        },
        {
          "name": "MCP_SERVER_PORT",
          "description": "Server port (default: 8010)",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://api.oneqaz.com/mcp"
    }
  ]
}
